class Solution(object):
    def eraseOverlapIntervals(self, listOfIntervals):
        if not listOfIntervals:
            return 0

        listOfIntervals.sort(key=lambda singleInterval: singleInterval[1])
        
        intervalsRemovedCount = 0
        endOfLastValidInterval = listOfIntervals[0][1]
        
        for currentIntervalIndex in range(1, len(listOfIntervals)):
            currentIntervalStart = listOfIntervals[currentIntervalIndex][0]
            currentIntervalEnd = listOfIntervals[currentIntervalIndex][1]
            
            if currentIntervalStart < endOfLastValidInterval:
                intervalsRemovedCount = intervalsRemovedCount + 1
            else:
                endOfLastValidInterval = currentIntervalEnd
                
        return intervalsRemovedCount